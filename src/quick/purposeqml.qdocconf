include($KDE_DOCS/global/qt-module-defaults.qdocconf)

project = PurposeQml
description = Framework for providing abstractions to get the developer's purposes fulfilled.

documentationinheaders = true

headerdirs = .
sourcedirs = .

outputdir  = doc/html
outputformats = HTML

depends += \
    kde \
    qtcore \
    qtqml \
    qtquickcontrols \
    purpose
